/* 个人中心页面样式 */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #6BA3E0 100%);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 菜单区块 */
.menu-section {
  padding: 24rpx;
}

.menu-group {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #F8F9FA;
}

.menu-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* 退出登录 */
.logout-section {
  padding: 24rpx 32rpx;
}

.btn-logout {
  width: 100%;
  height: 96rpx;
  background-color: #FFFFFF;
  color: #F5222D;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 20rpx;
  border: 2rpx solid #F5222D;
}

.btn-logout:active {
  background-color: rgba(245, 34, 45, 0.1);
}

/* 版本信息 */
.version-info {
  display: flex;
  justify-content: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #CCCCCC;
}
