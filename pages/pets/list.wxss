/* 宠物列表页面样式 */

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 宠物列表 */
.pet-list {
  display: flex;
  flex-direction: column;
}

.pet-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.pet-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.pet-detail {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.divider {
  margin: 0 12rpx;
}

.pet-weight {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 500;
}

.pet-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #4A90D9;
  color: #FFFFFF;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 24rpx rgba(74, 144, 217, 0.4);
  z-index: 999;
}

.fab:active {
  transform: scale(0.95);
}
