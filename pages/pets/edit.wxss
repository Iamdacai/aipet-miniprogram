/* 宠物编辑页面样式 */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 区块 */
.section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

/* 头像选择 */
.avatar-selector {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  margin-bottom: 24rpx;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.avatar-tips {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.avatar-options {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
}

.avatar-option {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 4rpx solid transparent;
}

.avatar-option:active {
  background-color: #E8E8E8;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.required {
  color: #F5222D;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 选择器 */
.picker {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 30rpx;
  color: #333333;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  gap: 32rpx;
}

.radio-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.radio-item.active {
  background-color: rgba(74, 144, 217, 0.1);
  border-color: #4A90D9;
}

.radio-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.radio-label {
  font-size: 28rpx;
  color: #666666;
}

.radio-item.active .radio-label {
  color: #4A90D9;
  font-weight: 600;
}

/* 复选框 */
.checkbox-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.checkbox-label {
  font-size: 28rpx;
  color: #333333;
}

.checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FFFFFF;
}

.checkbox.checked {
  background-color: #4A90D9;
  border-color: #4A90D9;
}

/* 提交按钮 */
.submit-bar {
  padding: 24rpx;
}

.submit-bar .btn {
  height: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.submit-bar .btn[disabled] {
  background-color: #CCCCCC;
}
