/* 宠物详情页面样式 */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 头部卡片 */
.header-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #6BA3E0 100%);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.pet-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.pet-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.pet-tags {
  display: flex;
  gap: 16rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background-color: rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
}

/* 区块 */
.section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row-label {
  font-size: 28rpx;
  color: #666666;
}

.info-row-value {
  font-size: 28rpx;
  color: #333333;
  max-width: 400rpx;
  text-align: right;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
}

.actions .btn {
  flex: 1;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-error {
  background-color: #F5222D;
  color: #FFFFFF;
}

.btn-error:active {
  background-color: #D9363E;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  font-size: 28rpx;
  color: #999999;
}
