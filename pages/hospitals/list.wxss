.container { padding: 24rpx; background: #F5F5F5; min-height: 100vh; }
.hospital-list { display: flex; flex-direction: column; gap: 24rpx; }
.hospital-card { background: #FFF; border-radius: 16rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.hospital-name { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.hospital-info { display: flex; gap: 24rpx; font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.hospital-address { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }
.hospital-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag { padding: 6rpx 16rpx; background: rgba(74,144,217,0.1); color: #4A90D9; border-radius: 8rpx; font-size: 24rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 160rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }
