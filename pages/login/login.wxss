/* 登录页面样式 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 48rpx 48rpx 24rpx;
  background: linear-gradient(180deg, #4A90D9 0%, #6BA3E0 100%);
}

/* 头部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo {
  font-size: 160rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 64rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单 */
.form {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 48rpx 24rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.input-wrapper {
  position: relative;
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  background-color: #F5F5F5;
  border-radius: 48rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.code-wrapper {
  display: flex;
  align-items: center;
}

.code-input {
  flex: 1;
  margin-right: 20rpx;
}

.code-btn {
  flex-shrink: 0;
  width: 240rpx;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #4A90D9;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 48rpx;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
}

.code-btn.disabled {
  background-color: #CCCCCC;
}

/* 登录按钮 */
.login-btn {
  margin-top: 48rpx;
  height: 100rpx;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
}

.login-btn[disabled] {
  background-color: #CCCCCC;
  box-shadow: none;
}

/* 协议说明 */
.agreement {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

.link {
  color: #4A90D9;
  text-decoration: underline;
  margin: 0 8rpx;
}

/* 底部说明 */
.footer {
  text-align: center;
  padding: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
