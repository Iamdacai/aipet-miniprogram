.container { padding: 32rpx; background: #F5F5F5; min-height: 100vh; }
.plan-title { font-size: 40rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.plan-status { display: inline-block; padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 26rpx; margin-bottom: 32rpx; }
.plan-status.active { background: rgba(82,196,26,0.1); color: #52C41A; }
.plan-status.completed { background: rgba(74,144,217,0.1); color: #4A90D9; }
.section { background: #FFF; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #999; margin-bottom: 16rpx; }
.content { font-size: 30rpx; color: #333; line-height: 1.6; }
.task { display: flex; align-items: flex-start; padding: 20rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.task:last-child { border-bottom: none; }
.task-icon { width: 48rpx; height: 48rpx; border-radius: 50%; border: 2rpx solid #4A90D9; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; font-size: 28rpx; color: #4A90D9; }
.task-icon.checked { background: #52C41A; border-color: #52C41A; color: #FFF; }
.task-content { flex: 1; }
.task-title { font-size: 30rpx; font-weight: 500; color: #333; margin-bottom: 8rpx; }
.task-desc { font-size: 26rpx; color: #999; }
.loading { display: flex; justify-content: center; padding: 100rpx; color: #999; }
