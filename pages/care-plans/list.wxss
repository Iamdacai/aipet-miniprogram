.container { padding: 24rpx; background: #F5F5F5; min-height: 100vh; }
.plan-list { display: flex; flex-direction: column; gap: 24rpx; }
.plan-card { background: #FFF; border-radius: 16rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.plan-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.plan-title { font-size: 32rpx; font-weight: 600; color: #333; }
.plan-status { padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; }
.plan-status.active { background: rgba(82,196,26,0.1); color: #52C41A; }
.plan-status.pending { background: rgba(250,173,20,0.1); color: #FAAD14; }
.plan-status.completed { background: rgba(74,144,217,0.1); color: #4A90D9; }
.plan-desc { font-size: 28rpx; color: #666; margin-bottom: 20rpx; line-height: 1.6; }
.plan-footer { display: flex; justify-content: space-between; font-size: 24rpx; color: #999; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 160rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }
