/* 首页样式 */

.container {
  padding: 0;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 顶部问候 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #6BA3E0 100%);
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.weather {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
}

.weather-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.weather-temp {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 快捷功能入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666666;
}

/* 区块 */
.section {
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

/* 宠物列表 */
.pet-list {
  display: flex;
  flex-direction: column;
}

.pet-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #F8F9FA;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.pet-card:last-child {
  margin-bottom: 0;
}

.pet-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #E8E8E8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.pet-detail {
  font-size: 24rpx;
  color: #999999;
}

.pet-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

.empty-pets {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

/* 提醒列表 */
.reminder-list {
  display: flex;
  flex-direction: column;
}

.reminder-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.reminder-content {
  flex: 1;
}

.reminder-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.reminder-time {
  font-size: 24rpx;
  color: #999999;
}

.reminder-status {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #4A90D9;
}

.reminder-status.completed {
  background-color: #4A90D9;
  color: #FFFFFF;
}

/* 文章列表 */
.article-list {
  display: flex;
  flex-direction: column;
}

.article-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.article-item:last-child {
  border-bottom: none;
}

.article-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.article-desc {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  align-items: center;
  font-size: 22rpx;
}

.article-category {
  padding: 4rpx 12rpx;
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.article-date {
  color: #CCCCCC;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #999999;
}
