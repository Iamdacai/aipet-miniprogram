<!-- 提醒编辑页面 -->
<view class="container">
  <form bindsubmit="onSubmit">
    <!-- 基本信息 -->
    <view class="section">
      <view class="section-title">提醒信息</view>
      
      <!-- 提醒类型 -->
      <view class="form-item">
        <view class="form-label">类型 <text class="required">*</text></view>
        <view class="type-selector">
          <view 
            class="type-item {{formData.type === 'feed' ? 'active' : ''}}"
            bindtap="selectType"
            data-type="feed"
          >
            <view class="type-icon">🍽️</view>
            <view class="type-label">喂食</view>
          </view>
          <view 
            class="type-item {{formData.type === 'medicine' ? 'active' : ''}}"
            bindtap="selectType"
            data-type="medicine"
          >
            <view class="type-icon">💊</view>
            <view class="type-label">喂药</view>
          </view>
          <view 
            class="type-item {{formData.type === 'vaccine' ? 'active' : ''}}"
            bindtap="selectType"
            data-type="vaccine"
          >
            <view class="type-icon">💉</view>
            <view class="type-label">疫苗</view>
          </view>
          <view 
            class="type-item {{formData.type === 'deworming' ? 'active' : ''}}"
            bindtap="selectType"
            data-type="deworming"
          >
            <view class="type-icon">🧪</view>
            <view class="type-label">驱虫</view>
          </view>
          <view 
            class="type-item {{formData.type === 'other' ? 'active' : ''}}"
            bindtap="selectType"
            data-type="other"
          >
            <view class="type-icon">📝</view>
            <view class="type-label">其他</view>
          </view>
        </view>
      </view>

      <!-- 提醒标题 -->
      <view class="form-item">
        <view class="form-label">标题 <text class="required">*</text></view>
        <input 
          class="input" 
          placeholder="例如：喂早餐、打疫苗"
          value="{{formData.title}}"
          bindinput="onInput"
          data-field="title"
          maxlength="50"
        />
      </view>

      <!-- 关联宠物 -->
      <view class="form-item">
        <view class="form-label">宠物</view>
        <picker 
          class="picker" 
          range="{{pets}}" 
          range-key="name"
          value="{{petIndex}}"
          bindchange="onPetChange"
        >
          <view class="picker-value">
            {{pets[petIndex]?.name || '选择宠物（可选）'}}
          </view>
        </picker>
      </view>

      <!-- 提醒日期 -->
      <view class="form-item">
        <view class="form-label">日期 <text class="required">*</text></view>
        <picker 
          class="picker" 
          mode="date" 
          value="{{formData.date}}"
          bindchange="onDateChange"
        >
          <view class="picker-value">
            {{formData.date || '选择日期'}}
          </view>
        </picker>
      </view>

      <!-- 提醒时间 -->
      <view class="form-item">
        <view class="form-label">时间 <text class="required">*</text></view>
        <picker 
          class="picker" 
          mode="time" 
          value="{{formData.time}}"
          bindchange="onTimeChange"
        >
          <view class="picker-value">
            {{formData.time || '选择时间'}}
          </view>
        </picker>
      </view>

      <!-- 重复设置 -->
      <view class="form-item">
        <view class="form-label">重复</view>
        <picker 
          class="picker" 
          range="{{repeatOptions}}" 
          value="{{repeatIndex}}"
          bindchange="onRepeatChange"
        >
          <view class="picker-value">
            {{repeatOptions[repeatIndex]}}
          </view>
        </picker>
      </view>

      <!-- 备注 -->
      <view class="form-item">
        <view class="form-label">备注</view>
        <textarea 
          class="textarea" 
          placeholder="补充说明（可选）"
          value="{{formData.notes}}"
          bindinput="onInput"
          data-field="notes"
          maxlength="200"
        />
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-bar">
      <button class="btn btn-primary btn-block" formType="submit" disabled="{{!canSubmit}}">
        {{isEdit ? '保存修改' : '添加提醒'}}
      </button>
    </view>
  </form>
</view>
