/* 提醒编辑页面样式 */

.container {
  padding: 24rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

/* 区块 */
.section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.required {
  color: #F5222D;
  margin-left: 4rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 选择器 */
.picker {
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.picker-value {
  font-size: 30rpx;
  color: #333333;
}

/* 类型选择器 */
.type-selector {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-item.active {
  background-color: rgba(74, 144, 217, 0.1);
  border-color: #4A90D9;
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 24rpx;
  color: #666666;
}

.type-item.active .type-label {
  color: #4A90D9;
  font-weight: 600;
}

/* 提交按钮 */
.submit-bar {
  padding: 24rpx;
}

.submit-bar .btn {
  height: 100rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.submit-bar .btn[disabled] {
  background-color: #CCCCCC;
}
