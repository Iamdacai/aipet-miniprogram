/* 文章详情页面样式 */

.container {
  height: 100vh;
  background-color: #FFFFFF;
}

.article-content {
  padding: 32rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.meta-item {
  margin-right: 24rpx;
}

.cover-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.article-body {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333333;
}

.article-body img {
  max-width: 100%;
  border-radius: 16rpx;
  margin: 24rpx 0;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx;
  font-size: 28rpx;
  color: #999999;
}
