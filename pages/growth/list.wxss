.container { padding: 24rpx; background: #F5F5F5; min-height: 100vh; }
.pet-selector { background: #FFF; padding: 24rpx; border-radius: 16rpx; margin-bottom: 24rpx; }
.pet-picker { font-size: 30rpx; color: #333; }
.timeline { position: relative; padding-left: 40rpx; }
.timeline::before { content: ''; position: absolute; left: 19rpx; top: 0; bottom: 0; width: 2rpx; background: #E8E8E8; }
.record-item { position: relative; margin-bottom: 32rpx; }
.record-dot { position: absolute; left: -40rpx; top: 0; width: 20rpx; height: 20rpx; border-radius: 50%; background: #4A90D9; border: 4rpx solid #FFF; box-shadow: 0 0 0 2rpx #E8E8E8; }
.record-card { background: #FFF; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.record-date { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }
.record-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.record-desc { font-size: 28rpx; color: #666; line-height: 1.6; margin-bottom: 16rpx; }
.record-image { width: 100%; height: 400rpx; border-radius: 12rpx; margin-top: 16rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 160rpx 48rpx; }
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.fab { position: fixed; right: 32rpx; bottom: 120rpx; width: 100rpx; height: 100rpx; border-radius: 50%; background: #4A90D9; color: #FFF; font-size: 56rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 24rpx rgba(74,144,217,0.4); z-index: 999; }
