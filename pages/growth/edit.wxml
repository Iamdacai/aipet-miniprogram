<view class="container">
  <form bindsubmit="onSubmit">
    <view class="section">
      <view class="form-item">
        <view class="form-label">标题</view>
        <input class="input" placeholder="例如：第一次洗澡" value="{{formData.title}}" bindinput="onInput" data-field="title" />
      </view>
      <view class="form-item">
        <view class="form-label">描述</view>
        <textarea class="textarea" placeholder="记录这一刻..." value="{{formData.description}}" bindinput="onInput" data-field="description" />
      </view>
      <view class="form-item">
        <view class="form-label">照片</view>
        <view class="image-picker" bindtap="chooseImage">
          <image class="preview-image" src="{{formData.image}}" mode="aspectFill" wx:if="{{formData.image}}" />
          <text wx:else>📸 点击拍照或选择照片</text>
        </view>
      </view>
    </view>
    <view class="submit-bar"><button class="btn btn-primary btn-block" formType="submit">保存</button></view>
  </form>
</view>
