.container { padding: 24rpx; background: #F5F5F5; min-height: 100vh; }
.section { background: #FFF; border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; }
.form-item { margin-bottom: 28rpx; }
.form-label { font-size: 28rpx; font-weight: 500; color: #333; margin-bottom: 16rpx; }
.input { width: 100%; height: 96rpx; padding: 0 24rpx; background: #F5F5F5; border-radius: 16rpx; font-size: 30rpx; box-sizing: border-box; }
.textarea { width: 100%; min-height: 200rpx; padding: 20rpx 24rpx; background: #F5F5F5; border-radius: 16rpx; font-size: 30rpx; line-height: 1.6; box-sizing: border-box; }
.image-picker { width: 100%; height: 300rpx; background: #F5F5F5; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; color: #999; font-size: 28rpx; }
.preview-image { width: 100%; height: 100%; border-radius: 16rpx; }
.submit-bar { padding: 24rpx; }
.submit-bar .btn { height: 100rpx; font-size: 34rpx; font-weight: 600; }
