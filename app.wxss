/**
 * Ai 宠 - 全局样式
 */

/* 全局变量 */
page {
  --primary-color: #4A90D9;
  --primary-dark: #3A7BC8;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --error-color: #F5222D;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border-color: #E8E8E8;
  --background-color: #F5F5F5;
  --white: #FFFFFF;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--text-primary);
  background-color: var(--background-color);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  background-color: var(--background-color);
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--white);
}

.btn-primary:active {
  background-color: var(--primary-dark);
}

.btn-secondary {
  background-color: var(--white);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-secondary:active {
  background-color: var(--background-color);
}

.btn-block {
  width: 100%;
}

.btn-small {
  height: 64rpx;
  font-size: 28rpx;
  border-radius: 32rpx;
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: var(--white);
  border: 2rpx solid var(--border-color);
  border-radius: 44rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--primary-color);
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: var(--white);
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
  margin-left: 24rpx;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
}

.tag-success {
  background-color: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.tag-warning {
  background-color: rgba(250, 173, 20, 0.1);
  color: var(--warning-color);
}

.tag-error {
  background-color: rgba(245, 34, 45, 0.1);
  color: var(--error-color);
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-state-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 32rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  color: var(--white);
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 24rpx rgba(74, 144, 217, 0.4);
  z-index: 999;
}

.fab:active {
  background-color: var(--primary-dark);
  transform: scale(0.95);
}
